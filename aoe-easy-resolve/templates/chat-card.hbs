<div class="pf2e-aoe-card">
  <header class="card-header" style="text-align: center; border-bottom: 2px solid var(--color-border-light-primary); margin-bottom: 5px; padding-bottom: 5px;">
    <h3 style="margin-bottom: 2px;">{{itemName}}</h3>
    {{#if saveDC}}
      <span style="font-size: 1.1em; font-weight: bold;">DC {{saveDC}} {{saveType}} Save</span><br>
    {{/if}}
    
    {{#if damageTotal}}
      <div style="margin-top: 5px;">
        <span class="damage-roll" style="font-weight: bold; color: #8b0000; font-size: 1.2em;" title="{{damageFormula}}">
          Damage: {{damageTotal}}
        </span>
      </div>
    {{else}}
      <button type="button" class="roll-damage-btn" style="margin-top: 5px;">
        <i class="fas fa-dice-d20"></i> Roll Damage
      </button>
    {{/if}}
  </header>

  <ul class="target-list" style="list-style: none; padding: 0; margin: 0 0 10px 0;">
    {{#each targets}}
      <li class="target-item" style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid rgba(0,0,0,0.15);">
        
        <div style="display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0; padding-right: 10px;">
          <img src="{{img}}" width="28" height="28" style="border: none; border-radius: 4px; flex-shrink: 0; box-shadow: 0 0 3px rgba(0,0,0,0.6);">
          <span style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="{{name}}">{{name}}</span>
        </div>
        
        <div style="flex-shrink: 0;">
          {{#if hasRolled}}
            <div style="text-align: right; padding-right: 4px; line-height: 1.1;">
              <div style="font-weight: bold; font-size: 1.1em;">{{rollTotal}}</div>
              <div style="font-size: 0.75em; font-weight: bold; text-transform: uppercase; color: {{dosColor}};">{{dosLabel}}</div>
            </div>
          {{else}}
            <button type="button" class="roll-save-btn" data-token-id="{{id}}" style="line-height: normal; padding: 2px 8px;">
              <i class="fas fa-dice-d20"></i> Save
            </button>
          {{/if}}
        </div>

      </li>
    {{/each}}
  </ul>

  <div style="display: flex; gap: 5px; margin-bottom: 5px;">
    {{#if isGM}}
      <button type="button" class="roll-all-npcs-btn" style="flex: 1; padding: 2px 5px; line-height: 1.2rem;">
        <i class="fas fa-users-cog"></i> Roll NPCs
      </button>
    {{/if}}
    <button type="button" class="apply-damage-btn" style="flex: 1; padding: 2px 5px; line-height: 1.2rem;">
      <i class="fas fa-heart-broken"></i> Apply Damage
    </button>
  </div>
</div>