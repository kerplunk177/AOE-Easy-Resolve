<form autocomplete="off" class="architect-dark-theme">
    <header class="architect-header">
        <img src="{{actor.img}}" title="{{actor.name}}" height="64" width="64" style="border: 2px solid #5a5954; border-radius: 5px;"/>
        <div style="margin-left: 10px;">
            <h1 style="border:none; margin:0;">{{actor.name}}</h1>
            <p style="margin: 0; color: #ccc;">Level {{actor.system.details.level.value}} {{currentRole}}</p>
        </div>
    </header>

    <nav class="architect-nav tabs" data-group="primary">
        <a class="item" data-tab="dossier"><i class="fas fa-book-open"></i> Dossier</a>
        <a class="item" data-tab="scaling"><i class="fas fa-chart-line"></i> Scaling</a>
        <a class="item" data-tab="builder"><i class="fas fa-hammer"></i> Builder</a>
        <a class="item" data-tab="connections"><i class="fas fa-network-wired"></i> Connections</a>
    </nav>

    <section class="architect-body">
        
        <div class="tab" data-tab="dossier">
            <div class="form-group dark-panel">
                <label><strong><i class="fas fa-eye"></i> Track in Campaign Hub?</strong></label>
                <div class="form-fields">
                    <input type="checkbox" name="tracked" {{checked tracked}}>
                </div>
            </div>

            <div class="form-group">
                <label><strong>Faction / Organization</strong></label>
                <div class="form-fields" style="display: flex; align-items: center; gap: 10px;">
                    <label style="color: #e0e0e0; white-space: nowrap; margin: 0;">
                        <input type="checkbox" name="isLocation" {{#if isLocation}}checked{{/if}}> 
                        Treat as Location
                    </label>
                    <input type="text" name="faction" value="{{faction}}" placeholder="e.g. City Watch, The Obsidian Cult" style="flex: 1; background: rgba(255,255,255,0.9); border: 1px solid #4b4a44; padding: 4px;">
                </div>
            </div>

            <div class="form-group">
                <label><strong>Campaign Arc</strong></label>
                <div class="form-fields">
                    <input type="text" name="campaign" value="{{campaign}}" placeholder="e.g. Global, Blood Lords, Extinction Curse..." style="width: 100%; box-sizing: border-box; background: rgba(255,255,255,0.9); border: 1px solid #4b4a44; padding: 4px;">
                </div>
            </div>

            <div class="form-group">
                <label><strong>Affiliation</strong></label>
                <div class="form-fields">
                    <select name="affiliation" style="width: 100%; background: rgba(255,255,255,0.9); border: 1px solid #4b4a44; padding: 4px; border-radius: 3px;">
                        {{selectOptions affiliations selected=affiliationStatus}}
                    </select>
                </div>
            </div>

            <hr>

            <div class="form-group">
                <h3>Public Knowledge (Appears on Card)</h3>
                <textarea name="bioPublic" rows="6" class="tile-input" style="margin-bottom: 10px;">{{bioPublic}}</textarea>
                
                <h3>GM Secrets (Private Notes)</h3>
                <textarea name="bioSecret" rows="6" class="tile-input dark-textarea">{{bioSecret}}</textarea>
            </div>
        </div>

        <div class="tab" data-tab="scaling">
            <div class="stat-box">
                <h3>Chassis Configuration</h3>
                <div class="form-group">
                    <label>Combat Role</label>
                    <select name="role">
                        {{selectOptions roles selected=currentRole}}
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Target Level</label>
                    <input type="number" name="targetLevel" value="{{actor.system.details.level.value}}">
                </div>
                <button type="button" class="apply-scaling-btn" style="margin-top: 10px;">
                    <i class="fas fa-bolt"></i> Apply Scaling Math
                </button>
            </div>
        </div>

        <div class="tab" data-tab="builder">
            <div class="builder-controls dark-panel" style="display:flex; gap:10px; margin-bottom:10px;">
                <select id="archetype-select" style="flex:1;">
                    <option value="">-- Select Class to Edit --</option>
                    {{#each savedArchetypes}}
                    <option value="{{id}}">{{name}}</option>
                    {{/each}}
                    <option value="new">+ Create New Class</option>
                </select>
                <button type="button" class="save-archetype-btn" style="flex:0 0 100px;"><i class="fas fa-save"></i> Save</button>
            </div>

            <div id="builder-editor" style="display:none;">
                <div class="form-group" style="display: flex; gap: 15px; align-items: center; margin-bottom: 15px;">
                    <div style="flex: 1;">
                        <label>Class Name</label>
                        <input type="text" id="arch-name" placeholder="e.g. Pyromancer">
                    </div>
                    <div style="flex: 1; display: flex; align-items: flex-end; gap: 10px; padding-bottom: 5px;">
                        <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; color: #e0e0e0; margin: 0;">
                            <input type="checkbox" id="arch-iscaster"> Is Spellcaster?
                        </label>
                        <select id="arch-tradition" style="display:none; width: 120px; background: rgba(255,255,255,0.9); color: #111; border: 1px solid #4b4a44; padding: 4px; border-radius: 3px;">
                            <option value="arcane">Arcane</option>
                            <option value="divine">Divine</option>
                            <option value="occult">Occult</option>
                            <option value="primal">Primal</option>
                        </select>
                    </div>
                </div>
                
                <div class="builder-grid-header" style="display:flex; background:#333; color:#e0e0e0; padding:5px; font-weight:bold; font-size:0.75em; align-items:center; border: 1px solid #444;">
                    <span style="flex:0 0 30px; text-align:center;">Lvl</span>
                    <span style="flex:0 0 45px; text-align:center;">HP</span>
                    <span style="flex:0 0 45px; text-align:center;">AC</span>
                    <span style="flex:0 0 45px; text-align:center;">Fort</span>
                    <span style="flex:0 0 45px; text-align:center;">Ref</span>
                    <span style="flex:0 0 45px; text-align:center;">Will</span>
                    <span style="flex:0 0 45px; text-align:center;">Per</span>
                    <span style="flex:1; padding-left:10px;">Features (Drag Items/Spells Here)</span>
                </div>

                <div class="level-container" style="height: 350px; overflow-y: auto; border:1px solid #444; border-top:none;">
                </div>
            </div>
        </div>

        <div class="tab" data-tab="connections">
            <div class="dark-panel">
                <h3>Relationship Tracker</h3>
                <p class="notes" style="margin-top:0; color:#aaa;">Link this NPC to PCs or other tracked members of the campaign hub.</p>
                
                <div id="connections-list">
                    {{#each connections}}
                    <div class="connection-row" style="display:flex; gap:10px; margin-bottom: 8px; align-items:center;">
                        <select class="conn-id" style="flex: 1; background: rgba(255,255,255,0.9); border: 1px solid #4b4a44; padding: 4px;">
                            {{selectOptions ../availableActors selected=this.id}}
                        </select>
                        <input type="text" class="conn-label" value="{{this.label}}" placeholder="e.g. Brother, Sworn Rival" style="flex: 1; background: rgba(255,255,255,0.9); border: 1px solid #4b4a44; padding: 4px;">
                        
                        <label style="display: flex; align-items: center; gap: 6px; cursor: pointer; color: #e0e0e0; background: rgba(0,0,0,0.4); padding: 4px 8px; border-radius: 4px; border: 1px solid #4b4a44; font-size: 12px; margin: 0;" title="Hide this connection from players">
                            <input type="checkbox" class="conn-secret" {{#if this.secret}}checked{{/if}} style="margin: 0;">
                            <i class="fas fa-user-secret"></i> Secret
                        </label>
                        
                        <button type="button" class="remove-connection-btn" style="flex: 0 0 30px; padding:0; height:30px;"><i class="fas fa-trash"></i></button>
                    </div>
                    {{/each}}
                </div>
                
                <button type="button" class="add-connection-btn" style="margin-top: 10px;">
                    <i class="fas fa-plus"></i> Add Connection
                </button>
            </div>
        </div>

    </section>
</form>

<style>
    .architect-dark-theme {
        background: #1c1b1a;
        color: #e0e0e0;
        padding: 10px;
        height: 100%;
        box-sizing: border-box;
    }

    .architect-dark-theme h1, 
    .architect-dark-theme h2, 
    .architect-dark-theme h3, 
    .architect-dark-theme label {
        color: #e0e0e0;
    }

    .architect-dark-theme .architect-nav {
        border-bottom: 2px solid #5a5954;
        margin-bottom: 15px;
    }

    .architect-dark-theme .architect-nav .item {
        color: #888;
    }

    .architect-dark-theme .architect-nav .item.active {
        color: #fff;
        text-shadow: 0 0 5px rgba(255,255,255,0.3);
    }

    .architect-dark-theme hr {
        border: 0;
        height: 2px;
        background: #5a5954;
        margin: 15px 0;
    }

    .architect-dark-theme input[type="text"], 
    .architect-dark-theme input[type="number"], 
    .architect-dark-theme select, 
    .architect-dark-theme .tile-input {
        background: rgba(255, 255, 255, 0.9);
        color: #111;
        border: 1px solid #4b4a44;
        width: 100%;
        resize: vertical;
        padding: 5px;
        border-radius: 3px;
    }

    .architect-dark-theme .dark-textarea {
        background: rgba(255, 255, 255, 0.6); 
    }

    .architect-dark-theme .dark-panel {
        background: rgba(255, 255, 255, 0.05);
        padding: 10px;
        border-radius: 4px;
        border: 1px solid #333;
    }
    
    .architect-dark-theme .builder-grid-header {
        border-color: #444;
    }

    .architect-dark-theme button {
        background: rgba(255, 255, 255, 0.1) !important;
        color: #e0e0e0 !important;
        border: 1px solid #5a5954 !important;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .architect-dark-theme button i {
        color: #e0e0e0 !important;
    }

    .architect-dark-theme button:hover {
        background: rgba(255, 255, 255, 0.2) !important;
        color: #fff !important;
        box-shadow: 0 0 5px rgba(255, 255, 255, 0.2) !important;
    }

    .architect-dark-theme button:hover i {
        color: #fff !important;
    }

    .architect-dark-theme .remove-connection-btn i {
        color: #ff8888 !important;
    }
    
    .architect-dark-theme .remove-connection-btn:hover {
        background: rgba(255, 0, 0, 0.2) !important;
        border-color: #ff8888 !important;
    }

    .architect-dark-theme .remove-connection-btn:hover i {
        color: #ffaaaa !important;
    }
</style>