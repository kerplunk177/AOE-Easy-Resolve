<div class="aoe-easy-resolve-card">
  <header style="text-align: center; margin-bottom: 10px; border-bottom: 2px solid #333; padding-bottom: 5px;">
    <h2 style="margin: 0;">{{itemName}}</h2>
    <div style="font-weight: bold; font-size: 1.2em;">DC {{saveDC}} {{saveType}} Save</div>
    
    {{#if damageTotal}}
      <div style="margin-top: 5px;">
        <span class="damage-roll" style="font-weight: bold; color: #ff6b6b; text-shadow: 1px 1px 2px black; font-size: 1.1em;" data-tooltip="{{#if damageTooltip}}{{damageTooltip}}{{else}}{{damageFormula}}{{/if}}" data-tooltip-direction="UP">
          Damage: {{#if damageBreakdown}}{{damageBreakdown}}{{else}}{{damageTotal}}{{/if}}
        </span>
      </div>
    {{/if}}
  </header>

  <div class="targets-section" style="display: flex; flex-direction: column; gap: 5px; margin-bottom: 10px;">
    {{#each targets}}
      <div class="target-row" data-token-id="{{id}}" style="display: flex; align-items: center; background: rgba(0, 0, 0, 0.2); padding: 5px; border-radius: 4px;">
        <img src="{{img}}" width="30" height="30" style="border: none; margin-right: 10px;" />
        <div class="target-name" style="flex: 1; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{name}}">{{name}}</div>
        
        <div class="target-save" style="flex: 0 0 105px; text-align: right;">
          {{#if isHealing}}
            <div data-token-id="{{id}}" style="font-weight: bold; color: #4ade80; text-shadow: 1px 1px 2px black; font-size: 1.1em; padding-top: 4px;" data-tooltip="Target receives healing automatically" data-tooltip-direction="UP">Healing</div>
          {{else if isImmune}}
            <div style="font-weight: bold; color: #9ca3af; font-size: 1.1em; padding-top: 4px;" data-tooltip="Target is immune to this effect" data-tooltip-direction="UP">Immune</div>
          {{else if hasRolled}}
            <div style="display: flex; flex-direction: row; align-items: center; justify-content: flex-end; gap: 5px;">
              
              <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div style="font-weight: bold; font-size: 1.1em;" data-tooltip="{{rollTooltip}}" data-tooltip-direction="UP">{{rollTotal}}</div>
                
                <div style="display: flex; align-items: center; justify-content: center; gap: 5px;">
                  {{#if ../isGM}}
                    <button class="step-dos-btn" data-token-id="{{id}}" data-direction="down" style="border: none; background: none; padding: 0; color: #888; font-size: 0.8em; cursor: pointer;" data-tooltip="Decrease Result" data-tooltip-direction="UP"><i class="fas fa-chevron-down"></i></button>
                  {{/if}}
                  
                  <div style="font-size: 0.8em; color: {{dosColor}}; font-weight: bold;">
                    {{dosLabel}}
                  </div>

                  {{#if ../isGM}}
                    <button class="step-dos-btn" data-token-id="{{id}}" data-direction="up" style="border: none; background: none; padding: 0; color: #888; font-size: 0.8em; cursor: pointer;" data-tooltip="Increase Result" data-tooltip-direction="UP"><i class="fas fa-chevron-up"></i></button>
                  {{/if}}
                </div>
                
                {{#if showUnadjusted}}
                  <div style="font-size: 0.7em; color: #888; text-decoration: line-through;" data-tooltip="Original unadjusted result" data-tooltip-direction="UP">
                    {{unadjustedDosLabel}}
                  </div>
                {{/if}}
              </div>

              {{#unless hasUsedHeroPoint}}
                <button class="hero-point-btn" data-token-id="{{id}}" style="padding: 2px 4px; line-height: 1; font-size: 0.9em; flex: 0 0 auto; background: rgba(255, 215, 0, 0.1); border: 1px solid #cca900; color: #cca900; border-radius: 3px;" data-tooltip="Spend a Hero Point to Reroll" data-tooltip-direction="UP">
                  <i class="fas fa-hospital-symbol"></i>
                </button>
              {{/unless}}
            </div>
          {{else}}
            <button class="roll-save-btn" data-token-id="{{id}}" style="padding: 2px 5px; font-size: 0.9em; width: 100%;">
              <i class="fas fa-dice-d20"></i> Save
            </button>
          {{/if}}
        </div>
      </div>
    {{/each}}
  </div>

  <div class="gm-controls" style="display: flex; flex-direction: column; gap: 5px; border-top: 1px solid #ccc; padding-top: 10px;">
    <div style="display: flex; gap: 5px;">
      <button class="roll-all-npcs-btn" style="flex: 1;"><i class="fas fa-users"></i> Roll NPCs</button>
      <button class="roll-damage-btn" style="flex: 1;"><i class="fas fa-tint"></i> Roll Damage</button>
    </div>
    <button class="apply-damage-btn" style="width: 100%; margin-top: 5px;"><i class="fas fa-heart-broken"></i> Apply Damage & Effects</button>
  </div>
</div>