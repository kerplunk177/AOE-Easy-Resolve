<div class="aoe-easy-resolve-card">
  <header style="text-align: center; margin-bottom: 10px; border-bottom: 2px solid #333; padding-bottom: 5px;">
    <h2 style="margin: 0;">{{itemName}}</h2>
    <div style="font-weight: bold; font-size: 1.2em;">DC {{saveDC}} {{saveType}} Save</div>
    
    {{#if damageTotal}}
      <div style="margin-top: 5px;">
        <span class="damage-roll" style="font-weight: bold; color: #ff6b6b; text-shadow: 1px 1px 2px black; font-size: 1.1em;" title="{{#if damageTooltip}}{{damageTooltip}}{{else}}{{damageFormula}}{{/if}}">
          Damage: {{#if damageBreakdown}}{{damageBreakdown}}{{else}}{{damageTotal}}{{/if}}
        </span>
      </div>
    {{/if}}
  </header>

  <div class="targets-section" style="display: flex; flex-direction: column; gap: 5px; margin-bottom: 10px;">
    {{#each targets}}
      <div class="target-row" style="display: flex; align-items: center; background: rgba(0, 0, 0, 0.2); padding: 5px; border-radius: 4px;">
        <img src="{{img}}" width="30" height="30" style="border: none; margin-right: 10px;" />
        <div class="target-name" style="flex: 1; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{name}}">{{name}}</div>
        
        <div class="target-save" style="flex: 0 0 80px; text-align: right;">
          {{#if isHealing}}
            <div style="font-weight: bold; color: #4ade80; text-shadow: 1px 1px 2px black; font-size: 1.1em; padding-top: 4px;" title="Target receives healing automatically">Healing</div>
          {{else if isImmune}}
            <div style="font-weight: bold; color: #9ca3af; font-size: 1.1em; padding-top: 4px;" title="Target is immune to this effect">Immune</div>
          {{else if hasRolled}}
            <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <div style="font-weight: bold; font-size: 1.1em;" title="{{rollTooltip}}">{{rollTotal}}</div>
              <div style="font-size: 0.8em; color: {{dosColor}};">
                {{dosLabel}}
              </div>
              {{#if showUnadjusted}}
                <div style="font-size: 0.7em; color: #888; text-decoration: line-through;" title="Original unadjusted result">
                  {{unadjustedDosLabel}}
                </div>
              {{/if}}
            </div>
              {{#if (ne degreeOfSuccess unadjustedDegreeOfSuccess)}}
                <div style="font-size: 0.7em; color: #888; text-decoration: line-through;" title="Original unadjusted result">
                  {{dosLabel unadjustedDegreeOfSuccess}}
                </div>
              {{/if}}
            </div>
          {{else}}
            <button class="roll-save-btn" data-token-id="{{id}}" style="padding: 2px 5px; font-size: 0.9em; width: 100%;" {{#unless ../isGM}} {{#unless isOwner}}disabled{{/unless}} {{/unless}}>
              <i class="fas fa-dice-d20"></i> Save
            </button>
          {{/if}}
        </div>
      </div>
    {{/each}}
  </div>

  {{#if isGM}}
    <div class="gm-controls" style="display: flex; flex-direction: column; gap: 5px; border-top: 1px solid #ccc; padding-top: 10px;">
      <div style="display: flex; gap: 5px;">
        <button class="roll-all-npcs-btn" style="flex: 1;"><i class="fas fa-users"></i> Roll NPCs</button>
        <button class="roll-damage-btn" style="flex: 1;"><i class="fas fa-tint"></i> Roll Damage</button>
      </div>
      <button class="apply-damage-btn" style="width: 100%; margin-top: 5px;"><i class="fas fa-heart-broken"></i> Apply Damage & Effects</button>
    </div>
  {{/if}}
</div>