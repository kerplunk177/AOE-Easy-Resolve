<fieldset>
  <legend>AoE Easy Resolve Configuration</legend>

  <div class="form-group">
    <label>Ignore AoE Automation?</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.ignoreAoE" {{checked ignoreAoE}}>
    </div>
  </div>

  <div class="form-group">
    <label>Override System Save?</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.useOverride" {{checked useOverride}}>
    </div>
  </div>

  <div class="form-group">
    <label>Provide Custom Template?</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.provideTemplate" {{checked provideTemplate}}>
    </div>
  </div>

  {{#if provideTemplate}}
  <div class="form-group">
    <label>Shape & Size</label>
    <div class="form-fields">
      <select name="flags.aoe-easy-resolve.templateType" style="width: 50%;">
        <option value="cone" {{#if isCone}}selected{{/if}}>Cone</option>
        <option value="circle" {{#if isCircle}}selected{{/if}}>Burst</option>
        <option value="ray" {{#if isRay}}selected{{/if}}>Line</option>
      </select>
      <input type="number" name="flags.aoe-easy-resolve.templateDistance" value="{{templateDistance}}" placeholder="ft." style="width: 50%;">
    </div>
  </div>
  {{/if}}

  <div class="form-group">
    <label>Save Type</label>
    <div class="form-fields">
      <select name="flags.aoe-easy-resolve.saveType">
        <option value="fortitude" {{#if isFort}}selected{{/if}}>Fortitude</option>
        <option value="reflex" {{#if isReflex}}selected{{/if}}>Reflex</option>
        <option value="will" {{#if isWill}}selected{{/if}}>Will</option>
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Custom DC</label>
    <div class="form-fields">
      <input type="number" name="flags.aoe-easy-resolve.saveDC" value="{{saveDC}}" placeholder="e.g. 15">
    </div>
  </div>

  <hr style="margin: 5px 0;">
  <p class="notes"><strong>Custom Damage Override</strong></p>
  
  <div class="form-group">
    <label>Use Custom Damage?</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.useCustomDamage" {{checked useCustomDamage}}>
    </div>
  </div>

  <div class="form-group">
    <label>Formula</label>
    <div class="form-fields">
      <input type="text" name="flags.aoe-easy-resolve.customDamage" value="{{customDamage}}" placeholder="e.g. 3d6">
    </div>
  </div>

  <div class="form-group">
    <label>Damage Type</label>
    <div class="form-fields">
      <select name="flags.aoe-easy-resolve.customDamageType">
        {{#each damageTypeOptions}}
          <option value="{{this.key}}" {{this.selected}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <hr style="margin: 5px 0;">
  <p class="notes"><strong>Basic Save Multipliers</strong></p>
  <div class="form-group"><label>Crit Success</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.criticalSuccess" value="{{multipliers.criticalSuccess}}" placeholder="0"></div></div>
  <div class="form-group"><label>Success</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.success" value="{{multipliers.success}}" placeholder="0.5"></div></div>
  <div class="form-group"><label>Failure</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.failure" value="{{multipliers.failure}}" placeholder="1"></div></div>
  <div class="form-group"><label>Crit Failure</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.criticalFailure" value="{{multipliers.criticalFailure}}" placeholder="2"></div></div>

  <hr style="margin: 5px 0;">
  <p class="notes"><strong>Target Matrix & Hazard Settings</strong></p>
  <div class="form-group">
    <label>Enemy Base Effect</label>
    <div class="form-fields">
      <select name="flags.aoe-easy-resolve.enemyBaseEffect">
        <option value="standard" {{#if enemyBaseStandard}}selected{{/if}}>Standard (Take Damage)</option>
        <option value="heal" {{#if enemyBaseHeal}}selected{{/if}}>Healing (Restore HP)</option>
        <option value="immune" {{#if enemyBaseImmune}}selected{{/if}}>Immune (Ignore Roll)</option>
      </select>
    </div>
  </div>
  <div class="form-group">
    <label>Ally Base Effect</label>
    <div class="form-fields">
      <select name="flags.aoe-easy-resolve.allyBaseEffect">
        <option value="standard" {{#if allyBaseStandard}}selected{{/if}}>Standard (Take Damage)</option>
        <option value="heal" {{#if allyBaseHeal}}selected{{/if}}>Healing (Restore HP)</option>
        <option value="immune" {{#if allyBaseImmune}}selected{{/if}}>Immune (Ignore Roll)</option>
      </select>
    </div>
  </div>
  <div class="form-group">
    <label>Hazard Duration (Rounds)</label>
    <div class="form-fields">
      <input type="number" name="flags.aoe-easy-resolve.hazardDuration" value="{{hazardDuration}}" placeholder="Leave blank for infinite">
    </div>
  </div>
  <div class="form-group">
    <label>Enable Tactical Drawing Tools?</label>
    <input type="checkbox" name="flags.aoe-easy-resolve.tacticalDrawing" {{checked tacticalDrawing}}>
    <p class="notes">Adds Freehand and Rectangle drawing tools to the chat card for custom hazard shapes.</p>
  </div>
</fieldset>


<fieldset style="margin-top: 15px;">
  <legend>Effect Rules Engine</legend>
  <p class="notes" style="margin-bottom: 10px;">Define specific triggers based on roll outcomes and target traits.</p>
  
  {{#each processedRules as |rule|}}
  <div style="border: 1px solid #7a7971; padding: 10px; margin-bottom: 10px; position: relative; background: rgba(0,0,0,0.1); border-radius: 3px;">
    <a class="delete-rule-btn" data-index="{{rule.index}}" style="position: absolute; top: 5px; right: 5px; color: #ff6666; cursor: pointer;" title="Delete Rule"><i class="fas fa-trash"></i></a>
    
    <div class="form-group">
      <label>Trigger</label>
      <div class="form-fields">
       <select name="flags.aoe-easy-resolve.rules.{{rule.index}}.context">
        <option value="attack" {{#if rule.isAttack}}selected{{/if}}>Attack Roll</option>
        <option value="save" {{#if rule.isSave}}selected{{/if}}>Save Result</option>
        <option value="reactiveSave" {{#if rule.isReactiveSave}}selected{{/if}}>Reactive Save (Hazard)</option>
        <option value="tokenEnter" {{#if rule.isTokenEnter}}selected{{/if}}>Token Enters Region</option>
        <option value="tokenExit" {{#if rule.isTokenExit}}selected{{/if}}>Token Exits Region</option>
        <option value="tokenMove" {{#if rule.isTokenMove}}selected{{/if}}>Moves Within Region</option>
        <option value="turnStart" {{#if rule.isTurnStart}}selected{{/if}}>Start of Turn</option>
        <option value="turnEnd" {{#if rule.isTurnEnd}}selected{{/if}}>End of Turn</option>
        </select>
        <select name="flags.aoe-easy-resolve.rules.{{rule.index}}.outcome">
          <option value="always" {{#if rule.isAlways}}selected{{/if}}>Always (Passive / Enter)</option>
          <option value="criticalSuccess" {{#if rule.isCS}}selected{{/if}}>Crit / Crit Success</option>
          <option value="success" {{#if rule.isS}}selected{{/if}}>Hit / Success</option>
          <option value="failure" {{#if rule.isF}}selected{{/if}}>Miss / Failure</option>
          <option value="criticalFailure" {{#if rule.isCF}}selected{{/if}}>Crit Miss / Crit Fail</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Target Scope</label>
      <div class="form-fields">
        <select name="flags.aoe-easy-resolve.rules.{{rule.index}}.alliance">
          <option value="all" {{#if rule.isAllianceAll}}selected{{/if}}>Affects Everyone</option>
          <option value="enemy" {{#if rule.isAllianceEnemy}}selected{{/if}}>Enemies Only</option>
          <option value="ally" {{#if rule.isAllianceAlly}}selected{{/if}}>Allies Only</option>
        </select>
      </div>
    </div>
    
    <div class="form-group">
      <label>Target Trait Requirement</label>
      <div class="form-fields">
        <input type="text" name="flags.aoe-easy-resolve.rules.{{rule.index}}.trait" value="{{rule.trait}}" placeholder="e.g. plant (leave blank for any target)">
      </div>
    </div>

    <div class="form-group">
      <label>Condition UUID</label>
      <div class="form-fields">
        <input type="text" name="flags.aoe-easy-resolve.rules.{{rule.index}}.conditionUuid" value="{{rule.conditionUuid}}" placeholder="Compendium.pf2e...">
      </div>
    </div>
    <div class="form-group">
        <label>Prompt Reactive Save?</label>
        <input type="checkbox" name="flags.aoe-easy-resolve.rules.{{rule.index}}.promptSave" {{#if rule.promptSave}}checked{{/if}}>
        <p class="notes">If checked, this rule will generate a new save card for the token instead of applying an effect.</p>
    </div>
    <div class="form-group">
      <label>Bonus Damage</label>
      <div class="form-fields">
        <input type="text" name="flags.aoe-easy-resolve.rules.{{rule.index}}.damageFormula" value="{{rule.damageFormula}}" placeholder="e.g. 1d6" style="width: 50%;">
        <select name="flags.aoe-easy-resolve.rules.{{rule.index}}.damageType" style="width: 50%;">
          {{#each rule.damageTypeOptions}}
            <option value="{{this.key}}" {{this.selected}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </div>
  {{/each}}

  <button type="button" class="add-rule-btn" style="margin-top: 5px;"><i class="fas fa-plus"></i> Add New Rule</button>
</fieldset>