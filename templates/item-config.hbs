<fieldset>
  <legend>AoE Easy Resolve Configuration</legend>

  <div class="form-group">
    <label>Ignore AoE Automation?</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.ignoreAoE" {{checked ignoreAoE}}>
    </div>
    <p class="notes">Check this to completely disable the AoE save card for this item.</p>
  </div>

  <div class="form-group">
    <label>Override System Save?</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.useOverride" {{checked useOverride}}>
    </div>
    <p class="notes">Check this to ignore the system's default save data.</p>
  </div>

  <div class="form-group">
    <label>Save Type</label>
    <div class="form-fields">
      <select name="flags.aoe-easy-resolve.saveType">
        <option value="fortitude" {{#if isFort}}selected{{/if}}>Fortitude</option>
        <option value="reflex" {{#if isReflex}}selected{{/if}}>Reflex</option>
        <option value="will" {{#if isWill}}selected{{/if}}>Will</option>
      </select>
    </div>
  </div>

  <div class="form-group">
    <label>Custom DC</label>
    <div class="form-fields">
      <input type="number" name="flags.aoe-easy-resolve.saveDC" value="{{saveDC}}" placeholder="e.g. 15">
    </div>
  </div>
  

  <hr style="margin: 5px 0;">
  <p class="notes"><strong>Custom Damage Override</strong></p>
  
  <div class="form-group">
    <label>Use Custom Damage?</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.useCustomDamage" {{checked useCustomDamage}}>
    </div>
    <p class="notes">Bypass item damage and roll this instead.</p>
  </div>

  <div class="form-group">
    <label>Formula</label>
    <div class="form-fields">
      <input type="text" name="flags.aoe-easy-resolve.customDamage" value="{{customDamage}}" placeholder="e.g. 3d6">
    </div>
  </div>

  <div class="form-group">
    <label>Damage Type</label>
    <div class="form-fields">
      <select name="flags.aoe-easy-resolve.customDamageType">
        {{#each damageTypeOptions}}
          <option value="{{this.key}}" {{this.selected}}>{{this.label}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <hr style="margin: 5px 0;">
  <p class="notes"><strong>Apply Effects (Compendium UUIDs)</strong></p>
  
  <div class="form-group"><label>Crit Success</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.effects.criticalSuccess" value="{{effects.criticalSuccess}}"></div></div>
  <div class="form-group"><label>Success</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.effects.success" value="{{effects.success}}"></div></div>
  <div class="form-group"><label>Failure</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.effects.failure" value="{{effects.failure}}"></div></div>
  <div class="form-group"><label>Crit Failure</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.effects.criticalFailure" value="{{effects.criticalFailure}}"></div></div>

  <hr style="margin: 5px 0;">
  <p class="notes"><strong>Damage Multipliers (Leave blank for standard Basic Save math)</strong></p>

  <div class="form-group"><label>Crit Success</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.criticalSuccess" value="{{multipliers.criticalSuccess}}" placeholder="0"></div></div>
  <div class="form-group"><label>Success</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.success" value="{{multipliers.success}}" placeholder="0.5"></div></div>
  <div class="form-group"><label>Failure</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.failure" value="{{multipliers.failure}}" placeholder="1"></div></div>
  <div class="form-group"><label>Crit Failure</label><div class="form-fields"><input type="number" step="0.5" name="flags.aoe-easy-resolve.multipliers.criticalFailure" value="{{multipliers.criticalFailure}}" placeholder="2"></div></div>
</fieldset>


<fieldset style="margin-top: 15px;">
  <legend>Attack Roll Configuration</legend>

  <div class="form-group">
    <label>Enable Attack Effects</label>
    <div class="form-fields">
      <input type="checkbox" name="flags.aoe-easy-resolve.attackEffects.enabled" {{checked attackEffects.enabled}}>
    </div>
    <p class="notes">Trigger conditions or extra damage based on the Strike's roll outcome.</p>
  </div>

  {{#if attackEffects.enabled}}
    <hr style="margin: 5px 0;">
    <p class="notes"><strong>Critical Hit</strong></p>
    <div class="form-group"><label>Condition UUID</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.attackEffects.criticalSuccess.conditionUuid" value="{{attackEffects.cs.conditionUuid}}" placeholder="Compendium.pf2e..."></div></div>
    <div class="form-group">
        <label>Bonus Damage</label>
        <div class="form-fields">
            <input type="text" name="flags.aoe-easy-resolve.attackEffects.criticalSuccess.damageFormula" value="{{attackEffects.cs.damageFormula}}" placeholder="e.g. 2d6" style="width: 50%;">
            <select name="flags.aoe-easy-resolve.attackEffects.criticalSuccess.damageType" style="width: 50%;">
                {{selectOptions damageTypesObj selected=attackEffects.cs.damageType blank="None / Untyped"}}
            </select>
        </div>
    </div>

    <hr style="margin: 5px 0;">
    <p class="notes"><strong>Hit</strong></p>
    <div class="form-group"><label>Condition UUID</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.attackEffects.success.conditionUuid" value="{{attackEffects.suc.conditionUuid}}" placeholder="Compendium.pf2e..."></div></div>
    <div class="form-group">
        <label>Bonus Damage</label>
        <div class="form-fields">
            <input type="text" name="flags.aoe-easy-resolve.attackEffects.success.damageFormula" value="{{attackEffects.suc.damageFormula}}" placeholder="e.g. 1d6" style="width: 50%;">
            <select name="flags.aoe-easy-resolve.attackEffects.success.damageType" style="width: 50%;">
                {{selectOptions damageTypesObj selected=attackEffects.suc.damageType blank="None / Untyped"}}
            </select>
        </div>
    </div>

    <hr style="margin: 5px 0;">
    <p class="notes"><strong>Miss</strong></p>
    <div class="form-group"><label>Condition UUID</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.attackEffects.failure.conditionUuid" value="{{attackEffects.fail.conditionUuid}}" placeholder="Compendium.pf2e..."></div></div>
    <div class="form-group">
        <label>Bonus Damage</label>
        <div class="form-fields">
            <input type="text" name="flags.aoe-easy-resolve.attackEffects.failure.damageFormula" value="{{attackEffects.fail.damageFormula}}" placeholder="e.g. 1" style="width: 50%;">
            <select name="flags.aoe-easy-resolve.attackEffects.failure.damageType" style="width: 50%;">
                {{selectOptions damageTypesObj selected=attackEffects.fail.damageType blank="None / Untyped"}}
            </select>
        </div>
    </div>

    <hr style="margin: 5px 0;">
    <p class="notes"><strong>Critical Miss</strong></p>
    <div class="form-group"><label>Condition UUID</label><div class="form-fields"><input type="text" name="flags.aoe-easy-resolve.attackEffects.criticalFailure.conditionUuid" value="{{attackEffects.cf.conditionUuid}}" placeholder="Compendium.pf2e..."></div></div>
    <div class="form-group">
        <label>Bonus Damage</label>
        <div class="form-fields">
            <input type="text" name="flags.aoe-easy-resolve.attackEffects.criticalFailure.damageFormula" value="{{attackEffects.cf.damageFormula}}" placeholder="e.g. 1" style="width: 50%;">
            <select name="flags.aoe-easy-resolve.attackEffects.criticalFailure.damageType" style="width: 50%;">
                {{selectOptions damageTypesObj selected=attackEffects.cf.damageType blank="None / Untyped"}}
            </select>
        </div>
    </div>
  {{/if}}
</fieldset>