<form autocomplete="off" class="archetype-builder">
    <div class="header-row">
        <label>Archetype Name:</label>
        <input type="text" name="name" value="{{archetype.name}}" placeholder="e.g. Goblin Pyro">
        <button type="submit"><i class="fas fa-save"></i> Save Archetype</button>
    </div>

    <div class="builder-grid-header">
        <span class="col-lvl">Lvl</span>
        <span class="col-stat">HP Logic</span>
        <span class="col-stat">AC Logic</span>
        <span class="col-items">Abilities / Features (Drag & Drop Here)</span>
    </div>

    <div class="level-container">
        {{#each archetype.levels as |lvl index|}}
        <div class="level-row" data-level="{{lvl.level}}">
            <div class="col-lvl"><strong>{{lvl.level}}</strong></div>
            
            <div class="col-stat">
                <select name="levels.{{index}}.hp">
                    {{selectOptions ../mathOptions selected=lvl.hp}}
                </select>
            </div>

            <div class="col-stat">
                <select name="levels.{{index}}.ac">
                    {{selectOptions ../mathOptions selected=lvl.ac}}
                </select>
            </div>

            <div class="col-items drop-zone">
                {{#each lvl.items as |item|}}
                <div class="item-tag" data-uuid="{{item.uuid}}">
                    <img src="{{item.img}}" width="20" height="20"> {{item.name}}
                    <a class="delete-item"><i class="fas fa-times"></i></a>
                </div>
                {{else}}
                <span class="placeholder">Drop items here...</span>
                {{/each}}
            </div>
        </div>
        {{/each}}
    </div>
</form>

<style>
    .archetype-builder { display: flex; flex-direction: column; height: 100%; }
    .header-row { flex: 0 0 50px; display: flex; gap: 10px; align-items: center; padding: 10px; border-bottom: 2px solid #444; }
    
    .builder-grid-header { display: flex; background: #ddd; padding: 5px; font-weight: bold; border-bottom: 1px solid #999; }
    .col-lvl { flex: 0 0 40px; text-align: center; }
    .col-stat { flex: 0 0 100px; padding: 0 5px; }
    .col-items { flex: 1; padding-left: 10px; }

    .level-container { flex: 1; overflow-y: auto; }
    .level-row { display: flex; align-items: center; padding: 5px; border-bottom: 1px solid #ccc; background: rgba(255,255,255,0.5); }
    .level-row:nth-child(even) { background: rgba(0,0,0,0.05); }

    .drop-zone { min-height: 30px; display: flex; flex-wrap: wrap; gap: 5px; align-items: center; }
    .item-tag { background: #4b4a44; color: #fff; padding: 2px 6px; border-radius: 4px; font-size: 0.8em; display: flex; align-items: center; gap: 5px; }
    .placeholder { color: #888; font-style: italic; font-size: 0.8em; }
</style>